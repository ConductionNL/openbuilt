{
	"info": {
		"_postman_id": "openbuilt-rbac-collection",
		"name": "OpenBuilt RBAC — REQ-OBRBAC-002..007",
		"description": "Newman integration suite for the openbuilt-rbac OpenSpec change. Exercises the manifest-endpoint security boundary (403 before 404 disambiguation, viewer/editor/owner read paths, audited admin bypass, transfer-ownership, list-endpoint IDOR closure) over real HTTP against a live Nextcloud instance with the `openbuilt` app enabled. The collection is self-contained: a Setup folder provisions a fresh seed Application, two test users, and a viewer/editor group; a Teardown folder removes every artefact so the suite is idempotent. Reuses the `admin/admin` credentials from the dev compose (memory rule).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "basic",
		"basic": [
			{ "key": "username", "value": "{{admin_user}}", "type": "string" },
			{ "key": "password", "value": "{{admin_password}}", "type": "string" }
		]
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8080", "type": "string" },
		{ "key": "admin_user", "value": "admin", "type": "string" },
		{ "key": "admin_password", "value": "admin", "type": "string" },
		{ "key": "viewer_user", "value": "rbac-viewer", "type": "string" },
		{ "key": "viewer_password", "value": "RbacViewer-1!", "type": "string" },
		{ "key": "editor_user", "value": "rbac-editor", "type": "string" },
		{ "key": "editor_password", "value": "RbacEditor-1!", "type": "string" },
		{ "key": "outsider_user", "value": "rbac-outsider", "type": "string" },
		{ "key": "outsider_password", "value": "RbacOutsider-1!", "type": "string" },
		{ "key": "viewer_group", "value": "openbuilt-rbac-viewers", "type": "string" },
		{ "key": "editor_group", "value": "openbuilt-rbac-editors", "type": "string" },
		{ "key": "test_slug", "value": "hello-world", "type": "string" },
		{ "key": "absent_slug", "value": "this-slug-definitely-does-not-exist", "type": "string" },
		{ "key": "application_uuid", "value": "", "type": "string" }
	],
	"item": [
		{
			"name": "Setup — provision users + groups + seeded Application",
			"description": "Creates two test users, a viewer group, an editor group, and binds the membership. The Application under test is the `hello-world` seed (created by the SeedHelloWorld repair step on app:enable); the PUT in step 3 patches its `permissions` block so our test users have known roles.",
			"item": [
				{
					"name": "1.1 Health check — Nextcloud reachable",
					"request": {
						"method": "GET",
						"url": { "raw": "{{base_url}}/status.php", "host": ["{{base_url}}"], "path": ["status.php"] }
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Nextcloud is installed and reachable', function () {",
									"    pm.response.to.have.status(200);",
									"    pm.expect(pm.response.json().installed).to.be.true;",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "1.2 Create viewer group",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "OCS-APIRequest", "value": "true" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{ "key": "groupid", "value": "{{viewer_group}}" }
							]
						},
						"url": {
							"raw": "{{base_url}}/ocs/v1.php/cloud/groups",
							"host": ["{{base_url}}"],
							"path": ["ocs", "v1.php", "cloud", "groups"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Viewer group created or already exists', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([100, 102, 200]);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "1.3 Create editor group",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "OCS-APIRequest", "value": "true" },
