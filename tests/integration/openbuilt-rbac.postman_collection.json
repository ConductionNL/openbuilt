		},
		{
			"name": "REQ-OBRBAC-002 — manifest endpoint enforces role membership",
			"description": "Validates getManifest's deny-by-default branch (no-role → 403, viewer → 200, admin → 200 + audit). Note the 403-before-404 disambiguation rule: the non-member must get 403, NOT 404, on an existing slug — otherwise the controller leaks slug existence.",
			"item": [
				{
					"name": "3.1 Outsider on existing slug — 403 BEFORE 404 (disambiguation)",
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{ "key": "username", "value": "{{outsider_user}}", "type": "string" },
								{ "key": "password", "value": "{{outsider_password}}", "type": "string" }
							]
						},
						"method": "GET",
						"header": [
							{ "key": "OCS-APIRequest", "value": "true" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/index.php/apps/openbuilt/api/applications/{{test_slug}}/manifest",
							"host": ["{{base_url}}"],
							"path": ["index.php", "apps", "openbuilt", "api", "applications", "{{test_slug}}", "manifest"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Outsider on existing slug gets 403 (not 404)', function () {",
									"    pm.response.to.have.status(403);",
									"});",
									"pm.test('Error envelope carries the fixed code openbuilt.rbac.no_role', function () {",
									"    const body = pm.response.json();",
									"    pm.expect(body).to.have.property('error');",
									"    pm.expect(body.code).to.equal('openbuilt.rbac.no_role');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "3.2 Viewer on existing slug — 200, manifest body returned",
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{ "key": "username", "value": "{{viewer_user}}", "type": "string" },
								{ "key": "password", "value": "{{viewer_password}}", "type": "string" }
							]
						},
						"method": "GET",
						"header": [
							{ "key": "OCS-APIRequest", "value": "true" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/index.php/apps/openbuilt/api/applications/{{test_slug}}/manifest",
							"host": ["{{base_url}}"],
							"path": ["index.php", "apps", "openbuilt", "api", "applications", "{{test_slug}}", "manifest"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Viewer gets 200 on the manifest endpoint', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Manifest body is returned UNWRAPPED (no OR envelope)', function () {",
									"    const body = pm.response.json();",
									"    pm.expect(body).to.be.an('object');",
									"    pm.expect(body).to.not.have.property('results');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "3.3 Admin on existing slug — 200 (admin bypass)",
					"description": "Admin is not in any of the permission groups (admin user is in the `admin` group, not in the editor/viewer groups). Per REQ-OBRBAC-006 the controller exercises the admin bypass and writes an `rbac.admin_bypass` event to OR's audit trail. The audit-trail row is asserted in step 3.4 below.",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "OCS-APIRequest", "value": "true" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/index.php/apps/openbuilt/api/applications/{{test_slug}}/manifest",
							"host": ["{{base_url}}"],
							"path": ["index.php", "apps", "openbuilt", "api", "applications", "{{test_slug}}", "manifest"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Admin gets 200 (bypass path)', function () {",
									"    pm.response.to.have.status(200);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "3.4 Admin bypass surfaces in OR audit trail",
					"description": "Queries OR's per-object audit trail endpoint for the Application. The previous admin manifest fetch should have appended a `rbac.admin_bypass` row. Falls back to a tolerant check when OR's audit endpoint shape varies across versions — the row is asserted by event name OR by message string.",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/index.php/apps/openregister/api/objects/openbuilt/application/{{application_uuid}}/audit-trails",
							"host": ["{{base_url}}"],
							"path": ["index.php", "apps", "openregister", "api", "objects", "openbuilt", "application", "{{application_uuid}}", "audit-trails"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Audit-trail endpoint returns 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"const body = pm.response.json();",
									"const rows = (body && body.results) || (Array.isArray(body) ? body : []);",
									"pm.test('rbac.admin_bypass event present', function () {",
									"    const bypassRow = rows.find(r => {",
									"        const haystack = JSON.stringify(r).toLowerCase();",
									"        return haystack.includes('admin_bypass') || haystack.includes('rbac.admin_bypass');",
									"    });",
									"    pm.expect(bypassRow, 'expected at least one rbac.admin_bypass audit row').to.not.be.undefined;",
									"});"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "REQ-OBRBAC-005 — owner-only transfer-ownership flow",
			"description": "Validates that PUT to an Application's `permissions` block is owner-gated: a viewer (or admin via bypass) sees the panel, but an unauthenticated transfer attempt by a viewer must be rejected. We do the happy-path transfer as admin (owner via bypass) and then assert that the orphan-check would reject an `owners = []` save.",
			"item": [
				{
					"name": "4.1 Admin transfers owners to editor group, viewer to old owner",
