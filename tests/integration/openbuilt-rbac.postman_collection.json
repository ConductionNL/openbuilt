							]
						},
						"url": {
							"raw": "{{base_url}}/ocs/v1.php/cloud/users",
							"host": ["{{base_url}}"],
							"path": ["ocs", "v1.php", "cloud", "users"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Outsider user created or already exists', function () {",
