							"raw": "{{base_url}}/ocs/v1.php/cloud/users/{{viewer_user}}/groups",
							"host": ["{{base_url}}"],
							"path": ["ocs", "v1.php", "cloud", "users", "{{viewer_user}}", "groups"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
