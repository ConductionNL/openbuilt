									"});"
								]
							}
						}
					]
				},
				{
					"name": "1.8 Assign editor user to editor group",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "OCS-APIRequest", "value": "true" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{ "key": "groupid", "value": "{{editor_group}}" }
							]
						},
						"url": {
							"raw": "{{base_url}}/ocs/v1.php/cloud/users/{{editor_user}}/groups",
							"host": ["{{base_url}}"],
							"path": ["ocs", "v1.php", "cloud", "users", "{{editor_user}}", "groups"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Editor user assigned to editor group', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([100, 102, 200]);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "1.9 Locate the hello-world Application and patch permissions",
					"description": "Looks up the Application by slug via OR's REST search, captures its uuid into the collection variable `application_uuid`, then PUTs a `permissions` block that grants the viewer group viewer role and the editor group editor role. Owners stays `admin`.",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/index.php/apps/openregister/api/objects/openbuilt/application?filter[slug]={{test_slug}}",
							"host": ["{{base_url}}"],
							"path": ["index.php", "apps", "openregister", "api", "objects", "openbuilt", "application"],
							"query": [
								{ "key": "filter[slug]", "value": "{{test_slug}}" }
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('OR returned the Application list', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"const body = pm.response.json();",
									"const rows = (body && body.results) || (Array.isArray(body) ? body : []);",
									"const app = rows.find(r => (r.slug === pm.collectionVariables.get('test_slug') || (r['@self'] && r['@self'].slug === pm.collectionVariables.get('test_slug'))));",
									"pm.test('hello-world Application present', function () {",
									"    pm.expect(app, 'expected to find the seeded hello-world Application').to.not.be.undefined;",
									"});",
									"if (app) {",
									"    const uuid = app.uuid || (app['@self'] && app['@self'].id) || app.id;",
									"    pm.collectionVariables.set('application_uuid', String(uuid));",
									"}"
								]
							}
						}
					]
				},
				{
					"name": "1.10 PUT permissions block (admin owner + viewer/editor groups)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\"permissions\":{\"owners\":[\"admin\"],\"editors\":[\"{{editor_group}}\"],\"viewers\":[\"{{viewer_group}}\"]}}"
						},
						"url": {
							"raw": "{{base_url}}/index.php/apps/openregister/api/objects/openbuilt/application/{{application_uuid}}",
							"host": ["{{base_url}}"],
							"path": ["index.php", "apps", "openregister", "api", "objects", "openbuilt", "application", "{{application_uuid}}"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Permissions block written', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
									"});"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "REQ-OBRBAC-003 — list-endpoint IDOR is closed",
			"description": "Validates ApplicationsController::listMine filters by per-Application permissions: viewer + editor see the seeded app, outsider sees an empty list. Failing this group surfaces the list-endpoint IDOR closed in commit 2389ec6.",
			"item": [
				{
					"name": "2.1 Viewer GET /api/applications sees the test app",
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{ "key": "username", "value": "{{viewer_user}}", "type": "string" },
								{ "key": "password", "value": "{{viewer_password}}", "type": "string" }
							]
						},
						"method": "GET",
						"header": [
							{ "key": "OCS-APIRequest", "value": "true" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/index.php/apps/openbuilt/api/applications",
							"host": ["{{base_url}}"],
							"path": ["index.php", "apps", "openbuilt", "api", "applications"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Viewer gets 200', function () { pm.response.to.have.status(200); });",
									"const list = pm.response.json();",
									"pm.test('Viewer sees the test app', function () {",
									"    pm.expect(Array.isArray(list)).to.be.true;",
									"    const match = list.find(a => a.slug === pm.collectionVariables.get('test_slug'));",
									"    pm.expect(match, 'viewer should see hello-world app').to.not.be.undefined;",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "2.2 Editor GET /api/applications sees the test app",
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{ "key": "username", "value": "{{editor_user}}", "type": "string" },
								{ "key": "password", "value": "{{editor_password}}", "type": "string" }
							]
						},
						"method": "GET",
						"header": [
							{ "key": "OCS-APIRequest", "value": "true" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/index.php/apps/openbuilt/api/applications",
							"host": ["{{base_url}}"],
							"path": ["index.php", "apps", "openbuilt", "api", "applications"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Editor gets 200', function () { pm.response.to.have.status(200); });",
									"const list = pm.response.json();",
									"pm.test('Editor sees the test app', function () {",
									"    pm.expect(Array.isArray(list)).to.be.true;",
									"    const match = list.find(a => a.slug === pm.collectionVariables.get('test_slug'));",
									"    pm.expect(match, 'editor should see hello-world app').to.not.be.undefined;",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "2.3 Outsider GET /api/applications returns empty list (no leak)",
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{ "key": "username", "value": "{{outsider_user}}", "type": "string" },
								{ "key": "password", "value": "{{outsider_password}}", "type": "string" }
							]
						},
						"method": "GET",
						"header": [
							{ "key": "OCS-APIRequest", "value": "true" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/index.php/apps/openbuilt/api/applications",
							"host": ["{{base_url}}"],
							"path": ["index.php", "apps", "openbuilt", "api", "applications"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Outsider gets 200', function () { pm.response.to.have.status(200); });",
									"const list = pm.response.json();",
									"pm.test('Outsider sees the seeded app in NO list — IDOR closed', function () {",
									"    pm.expect(Array.isArray(list)).to.be.true;",
									"    const match = list.find(a => a.slug === pm.collectionVariables.get('test_slug'));",
