{
  "name": "openbuilt",
  "version": "0.2.0",
  "license": "EUPL-1.2",
  "engines": {
    "node": "^20.0.0",
    "npm": "^10.0.0"
  },
  "scripts": {
    "build": "NODE_ENV=production webpack --config webpack.config.js --progress",
    "dev": "NODE_ENV=development webpack --config webpack.config.js --progress",
    "watch": "NODE_ENV=development webpack --config webpack.config.js --progress --watch",
    "lint": "eslint src",
    "lint-fix": "npm run lint -- --fix",
    "stylelint": "stylelint src/**/*.vue src/**/*.scss src/**/*.css",
    "stylelint-fix": "stylelint src/**/*.vue src/**/*.scss src/**/*.css --fix",
    "check:manifest": "node scripts/check-manifest.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install --with-deps",
    "test:newman": "newman run tests/integration/openbuilt.postman_collection.json --env-var base_url=http://localhost:8080 --env-var admin_user=admin --env-var admin_password=admin",
    "test:newman:ci": "newman run tests/integration/openbuilt.postman_collection.json --env-var base_url=http://localhost:8080 --env-var admin_user=admin --env-var admin_password=admin --reporters cli,junit --reporter-junit-export tests/integration/newman-results.xml",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "dependencies": {
    "@conduction/nextcloud-vue": "^1.0.0-beta.40",
    "@nextcloud/auth": "^2.4.0",
    "@nextcloud/axios": "~2.5.2",
    "@nextcloud/dialogs": "^3.2.0",
    "@nextcloud/initial-state": "^2.2.0",
    "@nextcloud/l10n": "^2.0.1",
    "@nextcloud/router": "^2.0.1",
    "@nextcloud/vue": "^8.16.0",
    "diff": "^5.2.0",
    "pinia": "^2.1.7",
    "vue": "^2.7.14",
    "vue-material-design-icons": "^5.3.0",
    "vue-router": "^3.6.5",
    "vuedraggable": "^2.24.3"
  },
  "overrides": {
    "libxmljs2": "^0.37.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@eslint/config-helpers": "^0.4.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@nextcloud/browserslist-config": "^3.0.1",
    "@nextcloud/eslint-config": "^8.4.1",
    "@nextcloud/stylelint-config": "^2.4.0",
    "@nextcloud/webpack-vue-config": "^6.0.1",
    "@playwright/test": "^1.48.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue2": "^2.3.4",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/test-utils": "^1.3.6",
    "css-loader": "~7.1.1",
    "eslint": "^8.56.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-vue": "^9.21.1",
    "jsdom": "^24.1.3",
    "newman": "^6.2.2",
    "sass": "^1.77.8",
    "sass-loader": "^16.0.2",
    "style-loader": "~4.0.0",
    "stylelint": "^15.11.0",
    "vitest": "^1.6.1",
    "vue-eslint-parser": "^9.4.3",
    "vue-loader": "^15.11.1 <16.0.0",
    "vue-template-compiler": "^2.7.16",
    "webpack": "^5.94.0",
    "webpack-cli": "^6.0.1"
  }
}
